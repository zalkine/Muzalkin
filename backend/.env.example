# MuZalkin backend — copy to .env and fill in values
# NEVER commit .env

PORT=3001

# Supabase — get from Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Anon key for reading cached_chords (authenticated-user reads)
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key for writing to cached_chords
# KEEP THIS SECRET — never expose to clients
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: restrict CORS to your mobile dev server or production domain
# CORS_ORIGIN=*
