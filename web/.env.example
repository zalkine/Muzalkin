# Web app environment — Vite
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.
#
# VITE_ prefix exposes vars to the client bundle (safe for publishable key only).
# Do NOT add VITE_ to the service-role key — it would be shipped to every browser.
# Get values from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key-here

# Backend URL (Railway or local)
VITE_BACKEND_URL=http://localhost:3001

# Service-role key — server-side / Edge Functions only. Never import in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
